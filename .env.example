DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth — genera con: npx auth secret
NEXTAUTH_SECRET="RANDOM_32_CHARACTER_STRING"

# URL del servicio picscrap (sin slash final)
SCRAPER_URL="https://your-scraper-service.com"

# API key del servicio picscrap (debe coincidir con API_KEY en picscrap)
SCRAPER_API_KEY="your-scraper-api-key"
